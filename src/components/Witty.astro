---
/* Witty: the corner "AI agent" that refuses to help. One joke, told once,
   dismissible forever. The avatar is the real logo mark, the same file the
   nav uses, so the refusal clearly comes from the site's own wolf and not
   from a bought widget. Rendered by Base on every page except /contact. */
---

<aside class="witty" data-witty aria-label="Witty, the site mascot" hidden>
  <div class="witty__bubble">
    <button class="witty__close" type="button" data-witty-close aria-label="Dismiss Witty">&times;</button>
    <p class="witty__line">
      Hi, I&rsquo;m Witty. I can&rsquo;t actually help you. But send me a DM
      through <a href="/contact">the form</a> and the human will.
    </p>
  </div>
  <img class="witty__wolf" src="/brand/wolf-mark.svg" alt="" width="87" height="110" />
</aside>

<style>
  .witty {
    position: fixed;
    right: clamp(0.75rem, 2vw, 1.5rem);
    bottom: 0;
    z-index: 55; /* above content; below the case pill (60), consent (70), wash (140) */
    /* bubble BESIDE the wolf, not above it: the ensemble stays inside the
       bottom ~150px strip instead of climbing over metric cards and prose */
    display: flex;
    flex-direction: row;
    align-items: flex-end;
    gap: 0.6rem;
    /* the container catches nothing: only the bubble and the wolf are solid */
    pointer-events: none;
    transform: translateY(16px);
    opacity: 0;
    transition: transform 0.45s var(--ease-out), opacity 0.35s ease-out;
  }
  .witty[hidden] { display: none; }
  .witty.is-in { transform: translateY(0); opacity: 1; }
  /* steps out (dismissal, or the footer owns the corner while on screen) */
  .witty.is-away { transform: translateY(110%); opacity: 0; }

  .witty__bubble {
    position: relative;
    pointer-events: auto;
    max-width: 250px;
    margin-bottom: 0.75rem; /* low in the corner strip, clear of the metric cards */
    padding: 0.85rem 2rem 0.85rem 1rem;
    background: var(--paper);
    border: 1.5px solid var(--ink);
    border-radius: 2px;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.02em;
    line-height: 1.6;
    color: var(--ink);
  }
  /* pointer tail toward the wolf, now on the bubble's right edge */
  .witty__bubble::after {
    content: "";
    position: absolute;
    right: -6.5px;
    bottom: 16px;
    width: 10px;
    height: 10px;
    background: inherit;
    border-top: 1.5px solid var(--ink);
    border-right: 1.5px solid var(--ink);
    transform: rotate(45deg);
  }
  .witty__line { margin: 0; }

  /* the typing caret, same block language as the site's typewriter */
  .witty__line :global(.witty__caret) {
    display: inline-block;
    width: 0.5em;
    height: 0.95em;
    margin-left: 1px;
    background: var(--ink);
    vertical-align: text-bottom;
  }

  /* the site's secondary-link language: amber, self-drawing underline */
  .witty__line a {
    color: var(--accent);
    text-decoration: none;
    background-image: linear-gradient(var(--accent), var(--accent));
    background-size: 0% 1px;
    background-position: 0 100%;
    background-repeat: no-repeat;
    transition: background-size 0.4s var(--ease-out);
    padding-bottom: 2px;
  }
  .witty__line a:hover,
  .witty__line a:focus-visible { background-size: 100% 1px; }
  .witty__line a:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }

  .witty__close {
    position: absolute;
    top: 0.2rem;
    right: 0.3rem;
    padding: 0.25rem;
    border: 0;
    background: none;
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 0.95rem;
    line-height: 1;
    color: var(--text-muted);
  }
  .witty__close:hover { color: var(--ink); }
  .witty__close:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }

  /* the wolf peeks up over the viewport edge, resting at the nav mark's tilt */
  .witty__wolf {
    display: block;
    pointer-events: auto;
    width: clamp(84px, 8vw, 104px);
    height: auto;
    margin-right: 0.9rem;
    margin-bottom: -14px;
    transform: rotate(-8deg);
    transform-origin: 50% 100%;
  }

  /* small mobile: the corner is contested (footer stack, inline CTAs), skip it */
  @media (max-width: 639px) {
    .witty { display: none; }
  }
  /* while the floating section pill owns the bottom edge on case pages */
  @media (max-width: 1023px) {
    :global(body:has([data-case-index])) .witty { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .witty { transition: none; }
  }
</style>

<script>
  // Chat-widget choreography: appear after a proper wait (the way those AI
  // assistants always do), then TYPE the message into the bubble. First
  // appearance per session performs; later pages show it already settled so
  // the gag never repeats. Dismissal is remembered in localStorage. While
  // the footer is on screen the corner belongs to the Cookies link, so
  // Witty steps out of the way. Re-binds after every view-transition swap.
  const KEY = "ww-witty";
  const SEEN = "ww-witty-seen";
  const WAIT = 6000; // the chatbot beat: late enough to miss the hero typing
  const CHAR = 22;   // ms per typed character

  function typeLine(el: HTMLElement, line: HTMLElement, done: () => void) {
    // collect every text node (the link's text included) so the message
    // types straight through the amber link without breaking it
    const nodes: Text[] = [];
    (function collect(n: Node) {
      n.childNodes.forEach((c) =>
        c.nodeType === 3 ? nodes.push(c as Text) : collect(c));
    })(line);
    const texts = nodes.map((n) => n.nodeValue ?? "");

    // freeze the bubble at its final size so typing never reflows it
    const bubble = line.closest<HTMLElement>(".witty__bubble");
    if (bubble) {
      const r = bubble.getBoundingClientRect();
      bubble.style.width = `${r.width}px`;
      bubble.style.height = `${r.height}px`;
    }
    nodes.forEach((n) => { n.nodeValue = ""; });

    const caret = document.createElement("span");
    caret.className = "witty__caret";
    caret.setAttribute("aria-hidden", "true");

    let j = 0, c = 0;
    const step = () => {
      if (el.hidden) { caret.remove(); return; } // dismissed mid-sentence
      if (j >= nodes.length) { caret.remove(); done(); return; }
      const node = nodes[j];
      node.nodeValue = texts[j].slice(0, ++c);
      node.parentNode?.insertBefore(caret, node.nextSibling);
      if (c >= texts[j].length) { j++; c = 0; }
      setTimeout(step, CHAR);
    };
    step();
  }

  function bind(el: HTMLElement) {
    if (el.dataset.bound) return;
    el.dataset.bound = "1";

    let dismissed = false;
    try { dismissed = localStorage.getItem(KEY) === "dismissed"; } catch {}
    if (dismissed) return;

    const reduced = matchMedia("(prefers-reduced-motion: reduce)").matches;
    let seen = false;
    try { seen = sessionStorage.getItem(SEEN) === "1"; } catch {}
    const line = el.querySelector<HTMLElement>(".witty__line");

    const show = () => {
      el.hidden = false;
      requestAnimationFrame(() => requestAnimationFrame(() => el.classList.add("is-in")));
    };

    if (reduced) {
      // simply present, full message, no motion
      el.hidden = false;
      el.classList.add("is-in");
    } else if (seen) {
      // already performed this session: settle in quietly, no typing
      setTimeout(show, 600);
    } else {
      setTimeout(() => {
        show();
        if (!line) return;
        // wolf up first, then the message types
        setTimeout(() => typeLine(el, line, () => {
          try { sessionStorage.setItem(SEEN, "1"); } catch {}
        }), 650);
      }, WAIT);
    }

    el.querySelector("[data-witty-close]")?.addEventListener("click", () => {
      try { localStorage.setItem(KEY, "dismissed"); } catch {}
      el.classList.remove("is-in");
      el.classList.add("is-away");
      setTimeout(() => { el.hidden = true; }, reduced ? 0 : 300);
    });

    const footer = document.querySelector("footer");
    if (footer && "IntersectionObserver" in window) {
      new IntersectionObserver((entries) => {
        for (const e of entries) el.classList.toggle("is-away", e.isIntersecting);
      }).observe(footer);
    }
  }

  function init() {
    const el = document.querySelector<HTMLElement>("[data-witty]");
    if (el) bind(el);
  }
  init();
  document.addEventListener("astro:page-load", init);
</script>
