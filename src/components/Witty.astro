---
/* Witty: the corner "AI agent" that refuses to help. One joke, told once,
   dismissible forever. The avatar is the real logo mark, the same file the
   nav uses. Rendered by Base on every page except contact, in every locale.

   Witty is also the language easter egg: on a first visit whose browser
   language differs from the page's, Witty offers the switch in the
   BROWSER's language, once, and remembers the answer. Never a redirect,
   never geolocation: navigator.language only, client-side. */
import { t, ui, type Locale } from "../i18n/ui";

const locale = (Astro.currentLocale ?? "en") as Locale;
const T = t(locale);
const prefix = locale === "en" ? "" : `/${locale}`;

/* every locale's offer strings ride along so the OFFER can speak the
   browser's language, whatever page it fires on */
const offers = Object.fromEntries(
  (Object.keys(ui) as Locale[]).map((l) => [
    l,
    { line: ui[l].witty.offer, yes: ui[l].witty.offerYes, no: ui[l].witty.offerNo },
  ])
);
---

<aside
  class="witty"
  data-witty
  data-witty-offers={JSON.stringify(offers)}
  aria-label={T.witty.ariaLabel}
  hidden
>
  <div class="witty__bubble">
    <button class="witty__close" type="button" data-witty-close aria-label={T.witty.dismiss}>&times;</button>
    <p class="witty__line" data-witty-line>
      {T.witty.lineBefore}<a href={`${prefix}/contact`}>{T.witty.lineLink}</a>{T.witty.lineAfter}
    </p>
    <p class="witty__actions" data-witty-actions hidden>
      <button class="witty__btn" type="button" data-witty-yes></button>
      <button class="witty__btn witty__btn--quiet" type="button" data-witty-no></button>
    </p>
  </div>
  <img class="witty__wolf" src="/brand/wolf-mark.svg" alt="" width="87" height="110" />
</aside>

<style>
  .witty {
    position: fixed;
    right: 0.75rem; /* truly in the corner */
    bottom: 0;
    z-index: 55; /* above content; below the case pill (60), consent (70), wash (140) */
    /* bubble BESIDE the wolf, not above it: the ensemble stays inside the
       bottom ~150px strip instead of climbing over metric cards and prose */
    display: flex;
    flex-direction: row;
    align-items: flex-end;
    gap: 0.6rem;
    /* the container catches nothing: only the bubble and the wolf are solid */
    pointer-events: none;
    transform: translateY(16px);
    opacity: 0;
    transition: transform 0.45s var(--ease-out), opacity 0.35s ease-out;
  }
  .witty[hidden] { display: none; }
  .witty.is-in { transform: translateY(0); opacity: 1; }
  /* steps out (dismissal, or the footer owns the corner while on screen) */
  .witty.is-away { transform: translateY(110%); opacity: 0; }

  .witty__bubble {
    position: relative;
    pointer-events: auto;
    max-width: 200px; /* narrow, so it stops sitting on body text */
    margin-bottom: 1.5rem; /* a touch higher, level with the wolf's face */
    padding: 0.85rem 2rem 0.85rem 1rem;
    background: var(--paper);
    border: 1.5px solid var(--ink);
    border-radius: 2px;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.02em;
    line-height: 1.6;
    color: var(--ink);
  }
  /* pointer tail toward the wolf, on the bubble's right edge */
  .witty__bubble::after {
    content: "";
    position: absolute;
    right: -6.5px;
    bottom: 16px;
    width: 10px;
    height: 10px;
    background: inherit;
    border-top: 1.5px solid var(--ink);
    border-right: 1.5px solid var(--ink);
    transform: rotate(45deg);
  }
  .witty__line { margin: 0; }

  /* the typing caret, same block language as the site's typewriter */
  .witty__line :global(.witty__caret) {
    display: inline-block;
    width: 0.5em;
    height: 0.95em;
    margin-left: 1px;
    background: var(--ink);
    vertical-align: text-bottom;
  }

  /* the site's secondary-link language: amber, self-drawing underline */
  .witty__line a {
    color: var(--accent);
    text-decoration: none;
    background-image: linear-gradient(var(--accent), var(--accent));
    background-size: 0% 1px;
    background-position: 0 100%;
    background-repeat: no-repeat;
    transition: background-size 0.4s var(--ease-out);
    padding-bottom: 2px;
  }
  .witty__line a:hover,
  .witty__line a:focus-visible { background-size: 100% 1px; }
  .witty__line a:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }

  /* the language-offer buttons: tiny field-notes rectangles, no pills */
  .witty__actions {
    margin: 0.6rem 0 0;
    display: flex;
    gap: 0.45rem;
    flex-wrap: wrap;
  }
  .witty__actions[hidden] { display: none; }
  .witty__btn {
    font: inherit;
    font-size: 0.68rem;
    letter-spacing: 0.04em;
    padding: 0.3rem 0.55rem;
    background: transparent;
    border: 1px solid var(--ink);
    border-radius: 2px;
    color: var(--ink);
    cursor: pointer;
  }
  .witty__btn:hover { background: var(--accent); border-color: var(--accent); color: var(--paper); }
  .witty__btn--quiet { border-color: var(--line); color: var(--text-muted); }
  .witty__btn--quiet:hover { background: transparent; border-color: var(--ink); color: var(--ink); }
  .witty__btn:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }

  .witty__close {
    position: absolute;
    top: 0.2rem;
    right: 0.3rem;
    padding: 0.25rem;
    border: 0;
    background: none;
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 0.95rem;
    line-height: 1;
    color: var(--text-muted);
  }
  .witty__close:hover { color: var(--ink); }
  .witty__close:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }

  /* the wolf peeks up over the viewport edge, resting at the nav mark's tilt */
  .witty__wolf {
    display: block;
    pointer-events: auto;
    width: clamp(80px, 7vw, 96px);
    height: auto;
    margin-bottom: -16px;
    transform: rotate(-8deg);
    transform-origin: 50% 100%;
  }

  /* small mobile: the corner is contested (footer stack, inline CTAs), skip it */
  @media (max-width: 639px) {
    .witty { display: none; }
  }
  /* while the floating section pill owns the bottom edge on case pages */
  @media (max-width: 1023px) {
    :global(body:has([data-case-index])) .witty { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .witty { transition: none; }
  }
</style>

<script>
  // Chat-widget choreography: appear after a proper wait, then TYPE the
  // message into the bubble. First appearance per session performs; later
  // pages show it settled. Dismissal is remembered forever. While the
  // footer is on screen the corner belongs to the Cookies link.
  //
  // Language offer: if the browser's primary language differs from the
  // page's and the site speaks it, the first performance is the offer, in
  // the browser's language, with two buttons. Any answer (or a manual
  // switch in the nav) is remembered and Witty never asks again.
  const KEY = "ww-witty";
  const SEEN = "ww-witty-seen";
  const OFFER_DONE = "ww-lang-offer";
  const LOCALE = "ww-locale";
  const WAIT = 6000;
  const CHAR = 22;
  const SUPPORTED = ["en", "nl", "es"];

  function store(k: string): string | null {
    try { return localStorage.getItem(k); } catch { return null; }
  }
  function put(k: string, v: string) {
    try { localStorage.setItem(k, v); } catch {}
  }

  function pageLocale(): string {
    return (document.documentElement.lang || "en").slice(0, 2);
  }
  function strippedPath(): string {
    const m = location.pathname.match(/^\/(nl|es)(\/.*|$)/);
    return m ? m[2] || "/" : location.pathname;
  }
  function pathIn(target: string): string {
    const base = strippedPath();
    return target === "en" ? base : `/${target}${base === "/" ? "/" : base}`;
  }

  function offerLocaleFor(): string | null {
    if (store(OFFER_DONE)) return null;
    let prefs: string[] = [];
    try {
      prefs = (navigator.languages && navigator.languages.length
        ? Array.from(navigator.languages)
        : [navigator.language || ""]
      ).map((l) => (l || "").slice(0, 2).toLowerCase());
    } catch {}
    const primary = prefs[0];
    if (primary && primary !== pageLocale() && SUPPORTED.includes(primary)) return primary;
    return null;
  }

  function typeLine(el: HTMLElement, line: HTMLElement, done: () => void) {
    const nodes: Text[] = [];
    (function collect(n: Node) {
      n.childNodes.forEach((c) =>
        c.nodeType === 3 ? nodes.push(c as Text) : collect(c));
    })(line);
    const texts = nodes.map((n) => n.nodeValue ?? "");

    // freeze the bubble at its final size so typing never reflows it
    const bubble = line.closest<HTMLElement>(".witty__bubble");
    if (bubble) {
      const r = bubble.getBoundingClientRect();
      bubble.style.width = `${r.width}px`;
      bubble.style.height = `${r.height}px`;
    }
    nodes.forEach((n) => { n.nodeValue = ""; });

    const caret = document.createElement("span");
    caret.className = "witty__caret";
    caret.setAttribute("aria-hidden", "true");

    let j = 0, c = 0;
    const step = () => {
      if (el.hidden) { caret.remove(); return; }
      if (j >= nodes.length) { caret.remove(); done(); return; }
      const node = nodes[j];
      node.nodeValue = texts[j].slice(0, ++c);
      node.parentNode?.insertBefore(caret, node.nextSibling);
      if (c >= texts[j].length) { j++; c = 0; }
      setTimeout(step, CHAR);
    };
    step();
  }

  function bind(el: HTMLElement) {
    if (el.dataset.bound) return;
    el.dataset.bound = "1";

    if (store(KEY) === "dismissed") return;

    const reduced = matchMedia("(prefers-reduced-motion: reduce)").matches;
    const line = el.querySelector<HTMLElement>("[data-witty-line]");
    const actions = el.querySelector<HTMLElement>("[data-witty-actions]");
    const yesBtn = el.querySelector<HTMLButtonElement>("[data-witty-yes]");
    const noBtn = el.querySelector<HTMLButtonElement>("[data-witty-no]");
    const standard = line ? (line.cloneNode(true) as HTMLElement) : null;

    const offerLang = offerLocaleFor();
    let offers: Record<string, { line: string; yes: string; no: string }> = {};
    try { offers = JSON.parse(el.dataset.wittyOffers ?? "{}"); } catch {}
    const offer = offerLang ? offers[offerLang] : null;

    const show = () => {
      el.hidden = false;
      requestAnimationFrame(() => requestAnimationFrame(() => el.classList.add("is-in")));
    };

    const armOffer = () => {
      if (!line || !actions || !yesBtn || !noBtn || !offer || !offerLang) return false;
      line.textContent = offer.line;
      yesBtn.textContent = offer.yes;
      noBtn.textContent = offer.no;
      actions.hidden = false;
      yesBtn.addEventListener("click", () => {
        put(LOCALE, offerLang);
        put(OFFER_DONE, "done");
        location.href = pathIn(offerLang);
      });
      noBtn.addEventListener("click", () => {
        put(OFFER_DONE, "done");
        // back to the normal line, instantly; the offer is over
        actions.hidden = true;
        if (standard) line.replaceChildren(...Array.from(standard.cloneNode(true).childNodes));
        const bubble = line.closest<HTMLElement>(".witty__bubble");
        if (bubble) { bubble.style.width = ""; bubble.style.height = ""; }
      });
      return true;
    };

    const offering = offer ? armOffer() : false;

    if (reduced) {
      // simply present, full message (offer included), no motion
      el.hidden = false;
      el.classList.add("is-in");
    } else if (store(SEEN) && !offering) {
      // already performed this session: settle in quietly, no typing
      setTimeout(show, 600);
    } else {
      setTimeout(() => {
        show();
        if (!line) return;
        setTimeout(() => {
          // typeLine freezes the bubble synchronously, so the buttons are
          // still visible for the measurement; hide them right after and
          // they reappear once the line has finished typing
          typeLine(el, line, () => {
            put(SEEN, "1");
            if (offering && actions) actions.hidden = false;
          });
          if (offering && actions) actions.hidden = true;
        }, 650);
      }, WAIT);
    }

    el.querySelector("[data-witty-close]")?.addEventListener("click", () => {
      put(KEY, "dismissed");
      el.classList.remove("is-in");
      el.classList.add("is-away");
      setTimeout(() => { el.hidden = true; }, reduced ? 0 : 300);
    });

    const footer = document.querySelector("footer");
    if (footer && "IntersectionObserver" in window) {
      new IntersectionObserver((entries) => {
        for (const e of entries) el.classList.toggle("is-away", e.isIntersecting);
      }).observe(footer);
    }
  }

  function init() {
    const el = document.querySelector<HTMLElement>("[data-witty]");
    if (el) bind(el);
  }
  init();
  document.addEventListener("astro:page-load", init);
</script>
