---
/* The numbered work index, shared by the home page (compact) and /work
   (detailed, which adds each project's summary line in the reading face).
   One implementation so the two never drift apart. Pure type: mono number
   and year outside, client and tagline inside, hairlines between rows;
   the whole row is the link and carries data-accent for the curtain. */
import type { CollectionEntry } from "astro:content";

interface Props {
  work: CollectionEntry<"work">[];
  variant?: "compact" | "detailed";
  label?: string;
}
const { work, variant = "compact", label = "Selected work" } = Astro.props;
---

<div class="windex">
  <header class="index-head mono" data-reveal>
    <span>{label}</span>
    <span>{String(work.length).padStart(2, "0")} projects</span>
  </header>
  <ul class="index" data-reveal-group>
    {work.map((w, i) => (
      <li>
        <a
          href={`/work/${w.slug}`}
          class="row"
          data-reveal
          data-accent={w.data.accent}
        >
          <span class="row__num mono">{String(i + 1).padStart(2, "0")}</span>
          <span class="row__body">
            <span class="row__client">{w.data.client}</span>
            <span class="row__tag">{w.data.tagline}</span>
            {variant === "detailed" && (
              <span class="row__summary">{w.data.summary}</span>
            )}
          </span>
          <span class="row__meta mono">
            <span class="row__role">{w.data.role}</span>
            <span class="row__year">{w.data.year}</span>
          </span>
        </a>
      </li>
    ))}
  </ul>
</div>

<style>
  .windex { position: relative; }

  .index-head {
    display: flex; justify-content: space-between; gap: 1rem;
    font-size: 0.78rem;
    color: var(--text-muted);
    padding-bottom: 0.8rem;
  }
  /* with room to spare, the label hangs in the left margin outside the
     column, top-aligned with the first row; narrower screens keep it
     inside the column above the list */
  @media (min-width: 1520px) {
    .index-head {
      position: absolute;
      left: -9.5rem;
      top: clamp(1.2rem, 3vw, 1.9rem);
      width: 8rem;
      display: block;
      padding-bottom: 0;
    }
    .index-head span { display: block; }
    .index-head span + span { margin-top: 0.35rem; }
  }

  .index { list-style: none; margin: 0; padding: 0; border-top: 1px solid var(--line); }
  .index li { border-bottom: 1px solid var(--line); }
  .row {
    display: grid;
    grid-template-columns: 3.5rem 1fr auto;
    align-items: baseline;
    gap: clamp(0.75rem, 2.5vw, 2rem);
    padding-block: clamp(1.2rem, 3vw, 1.9rem);
    transition: transform 0.18s ease-out;
  }
  .row:hover { transform: translateY(-2px); }
  .row:focus-visible { outline: 2px solid var(--accent); outline-offset: 4px; }
  .row__num {
    color: var(--text-muted);
    font-size: 0.78rem;
    transition: color 0.18s ease-out;
  }
  .row:hover .row__num { color: var(--accent); }
  .row__body { display: grid; gap: 0.3rem; }
  .row__client {
    font-family: var(--font-mono); font-weight: 650;
    font-size: clamp(1.1rem, 1.9vw, 1.5rem);
    line-height: 1.15; letter-spacing: -0.02em; color: var(--ink);
  }
  .row__tag {
    font-family: var(--font-mono); font-weight: 400;
    font-size: clamp(0.82rem, 1.2vw, 0.95rem);
    line-height: 1.4; color: var(--text-muted);
  }
  /* detailed variant only: the summary line, in the reading face */
  .row__summary {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--text-muted);
    max-width: 56ch;
    margin-top: 0.35rem;
  }
  /* quiet meta: role and year, right-aligned on wide rows */
  .row__meta {
    display: grid; gap: 0.25rem;
    text-align: right;
    color: var(--text-muted);
    font-size: 0.72rem;
    max-width: 20rem;
  }
  .row__year { font-size: 0.78rem; }
  @media (max-width: 640px) {
    /* meta drops under the tagline so nothing fights for width */
    .row { grid-template-columns: 3.5rem 1fr; }
    .row__meta {
      grid-column: 2;
      display: flex; flex-wrap: wrap; gap: 0.25rem 1rem;
      text-align: left;
      margin-top: 0.4rem;
    }
  }
</style>
