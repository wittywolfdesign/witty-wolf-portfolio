---
/* Section index / scroll-spy for a case study. Server-rendered from the case's
   own `<p class="note">` labels (the single source of truth, parsed in
   [slug].astro), so it is a working list of anchor links with JavaScript off.
   Progressive enhancement, added only once the script boots:
     - desktop (>= 1024px): a sticky rail in the left margin, active section lit
     - mobile  (<  1024px): a floating pill showing the current section, tap to
       expand the full list
   The same script optionally retitles the document to the active section, for
   cleaner macOS window-capture filenames. See the <script> below. */
interface Props {
  sections: { label: string; id: string }[];
  client: string;
  baseTitle: string;
}
const { sections, client, baseTitle } = Astro.props;
---

{sections.length > 0 && (
  <nav
    class="case-index"
    aria-label="Sections"
    data-case-index
    data-case-client={client}
    data-case-title={baseTitle}
  >
    <h2 class="case-index__heading mono">On this page</h2>
    <ol class="case-index__list" id="case-index-list">
      {sections.map((s, i) => (
        <li class="case-index__item">
          <a class="case-index__link" href={`#${s.id}`} data-index-link data-index={i}>
            {s.label}
          </a>
        </li>
      ))}
    </ol>
    <button
      class="case-index__pill"
      type="button"
      data-index-pill
      aria-expanded="false"
      aria-controls="case-index-list"
    >
      <span class="case-index__pill-label" data-index-current>{sections[0].label}</span>
      <span class="case-index__pill-caret" aria-hidden="true"></span>
    </button>
  </nav>
)}

<style>
  /* Base / no-JS / small-screen default: a plain, in-flow block of anchor
     links. Everything sticky or floating is layered on only when the script
     adds .case-index--js (and the parent adds .case-has-index). */
  .case-index {
    margin: 0 0 2.5rem;
    padding: 1.1rem 1.25rem 1.25rem;
    border: 1px solid var(--line);
    border-left: 2px solid var(--case-accent, var(--accent));
    background: var(--bg-elevated);
  }
  .case-index__heading {
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin: 0 0 0.75rem;
  }
  .case-index__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.1rem;
  }
  .case-index__link {
    display: block;
    padding: 0.35rem 0;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-muted);
    transition: color 0.2s ease;
  }
  .case-index__link:hover,
  .case-index__link:focus-visible { color: var(--ink); }
  .case-index__link.is-active { color: var(--case-accent, var(--accent)); }

  /* the pill trigger only exists in the enhanced mobile layout */
  .case-index__pill { display: none; }

  /* ---- enhanced desktop: sticky rail in the left margin ---------------- */
  /* The grid itself lives on .prose-wrap in [slug].astro; here we only style
     the rail, gated on the nav's own .case-index--js (Astro scopes every
     compound selector, so we cannot reach the parent .prose-wrap from here).
     Sticky top clears the 64px sticky nav (the metaline is not sticky, so it
     scrolls away and needs no allowance). */
  @media (min-width: 1024px) {
    .case-index--js {
      position: sticky;
      top: var(--rail-top, 5.5rem);
      align-self: start;
      margin: 0;
      padding: 0;
      border: 0;
      background: none;
      max-height: calc(100vh - var(--rail-top, 5.5rem) - 2rem);
      overflow: auto;
    }
    .case-index--js .case-index__heading { margin-bottom: 1rem; }
    .case-index--js .case-index__list {
      border-left: 1px solid var(--line);
      gap: 0;
    }
    .case-index--js .case-index__link {
      padding: 0.4rem 0 0.4rem 0.9rem;
      margin-left: -1px;
      border-left: 2px solid transparent;
      font-size: 0.68rem;
      line-height: 1.3;
    }
    .case-index--js .case-index__link.is-active {
      border-left-color: var(--case-accent, var(--accent));
      color: var(--case-accent, var(--accent));
    }
  }

  /* ---- wide desktop (>=1520px): rail hangs in the left margin -----------
     The parent .prose-wrap drops its grid at this width (see [slug].astro), so
     pull the still-sticky rail fully into the gutter with a float plus a
     matching negative margin (rail width + the 2rem gap). The float then sits
     entirely left of the content column, so the prose flows full-width from
     the wrap's left edge; float and position:sticky co-exist, so it also keeps
     tracking the scroll. */
  @media (min-width: 1520px) {
    .case-index--js {
      float: left;
      width: clamp(7rem, 8vw, 9.5rem);
      margin-left: calc(-1 * (clamp(7rem, 8vw, 9.5rem) + 2rem));
    }
  }

  /* ---- enhanced mobile: floating current-section pill ------------------ */
  @media (max-width: 1023px) {
    .case-index--js {
      position: fixed;
      left: 50%;
      bottom: 1.25rem;
      transform: translateX(-50%);
      z-index: 60;
      width: min(92%, 30rem);
      margin: 0;
      padding: 0;
      border: 0;
      background: none;
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
    }
    .case-index--js.is-visible {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
    }
    .case-index--js .case-index__heading { display: none; }

    .case-index--js .case-index__pill {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      width: 100%;
      padding: 0.7rem 1rem;
      background: var(--bg-elevated);
      border: 1px solid var(--line);
      box-shadow: 0 6px 24px rgba(0, 0, 0, 0.18);
      font-family: var(--font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: var(--ink);
      cursor: pointer;
    }
    .case-index--js .case-index__pill-label {
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .case-index--js .case-index__pill-caret {
      flex: none;
      width: 0.5rem;
      height: 0.5rem;
      border-right: 1.5px solid currentColor;
      border-bottom: 1.5px solid currentColor;
      transform: rotate(-135deg); /* points up: tap to open upward */
      transition: transform 0.25s ease;
    }
    .case-index--js.is-open .case-index__pill-caret { transform: rotate(45deg); }

    .case-index--js .case-index__list {
      position: absolute;
      left: 0;
      right: 0;
      bottom: calc(100% + 0.5rem);
      background: var(--bg-elevated);
      border: 1px solid var(--line);
      box-shadow: 0 -6px 24px rgba(0, 0, 0, 0.18);
      padding: 0.5rem 0.85rem;
      max-height: 50vh;
      overflow: auto;
      opacity: 0;
      visibility: hidden;
      transform: translateY(0.5rem);
    }
    .case-index--js.is-open .case-index__list {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }
    .case-index--js .case-index__link {
      padding: 0.55rem 0.25rem;
      font-size: 0.74rem;
    }
    .case-index--js .case-index__link.is-active { color: var(--case-accent, var(--accent)); }
  }

  /* motion is opt-in: reduced-motion users get the index fully present, no
     slide/fade on reveal or expand (smooth scroll is gated in the script) */
  @media (prefers-reduced-motion: no-preference) {
    .case-index--js,
    .case-index--js .case-index__list {
      transition: opacity 0.3s ease, visibility 0.3s ease, transform 0.3s ease;
    }
  }
</style>

<script>
  import { slug } from "../scripts/slug.mjs";

  // Retitle the document to the active section as you scroll, so a macOS
  // window capture (Shift-Cmd-4 then Space) is named for what is on screen,
  // e.g. "Urbiqo · 02 · Trust · Witty Wolf". Region, full-screen and iOS
  // captures ignore the window title and stay generic, so this only helps
  // that one capture mode. The title also shows in the tab and history, so we
  // keep it short and only ever write it on an actual section change.
  const DYNAMIC_TITLE = true;

  // A note is "active" once its top passes this line below the sticky nav.
  const ACTIVATE_LINE = 120;

  interface CaseIndexCleanup { (): void }
  let teardown: CaseIndexCleanup | null = null;
  // guard against the double-init on first load (the direct call below AND
  // astro:page-load both fire); teardown re-arms it before each swap
  let inited = false;

  function initCaseIndex(): void {
    if (inited) return;
    const nav = document.querySelector<HTMLElement>("[data-case-index]");
    if (!nav) return;
    inited = true;
    const proseWrap = nav.closest<HTMLElement>(".prose-wrap");
    const prose = proseWrap?.querySelector<HTMLElement>(".prose");
    if (!proseWrap || !prose) return;

    const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;

    // Assign ids to the rendered .note anchors in order, using the same slug
    // as the build. Ids are already stamped at build (rehype), so this is a
    // belt-and-braces resync that keeps SSR hrefs and live ids aligned.
    const notes = Array.from(prose.querySelectorAll<HTMLElement>(".note"));
    notes.forEach((el) => {
      const id = slug(el.textContent || "");
      if (id && el.id !== id) el.id = id;
    });

    const links = Array.from(nav.querySelectorAll<HTMLAnchorElement>("[data-index-link]"));
    const pill = nav.querySelector<HTMLElement>("[data-index-pill]");
    const pillLabel = nav.querySelector<HTMLElement>("[data-index-current]");
    // next-case card marks the end of the readable body: hide the pill there
    const nextcard = document.querySelector<HTMLElement>(".nextcard");
    // pair each link with its note by order (both derive from the same source)
    const count = Math.min(links.length, notes.length);

    // enable the enhanced layout (base/no-JS stays a plain in-flow list)
    proseWrap.classList.add("case-has-index");
    nav.classList.add("case-index--js");

    const baseTitle = nav.dataset.caseTitle || document.title;
    const client = nav.dataset.caseClient || "";
    const originalTitle = document.title;

    let activeIndex = -1;
    let raf = 0;

    const setTitle = (t: string) => {
      if (DYNAMIC_TITLE && document.title !== t) document.title = t;
    };

    const apply = (idx: number) => {
      if (idx !== activeIndex) {
        activeIndex = idx;
        links.forEach((l, i) => {
          const on = i === idx;
          l.classList.toggle("is-active", on);
          if (on) l.setAttribute("aria-current", "true");
          else l.removeAttribute("aria-current");
        });
        if (pillLabel && idx >= 0) pillLabel.textContent = links[idx].textContent;
        setTitle(idx >= 0 ? `${client} · ${links[idx].textContent} · Witty Wolf` : baseTitle);
      }
      // reveal the mobile pill once past the intro, hide it around the footer
      const nearFooter = nextcard
        ? nextcard.getBoundingClientRect().top < window.innerHeight * 0.9
        : false;
      const show = idx >= 0 && !nearFooter;
      nav.classList.toggle("is-visible", show);
      if (!show) nav.classList.remove("is-open");
    };

    const compute = () => {
      raf = 0;
      let idx = -1;
      for (let i = 0; i < count; i++) {
        if (notes[i].getBoundingClientRect().top <= ACTIVATE_LINE) idx = i;
        else break;
      }
      apply(idx);
    };

    const onScroll = () => {
      if (!raf) raf = requestAnimationFrame(compute);
    };

    // smooth-scroll on click (respecting reduced motion), sync the hash, and
    // collapse the mobile pill after picking a section
    const onLinkClick = (e: MouseEvent) => {
      const link = (e.currentTarget as HTMLAnchorElement);
      const id = link.getAttribute("href")?.slice(1);
      const target = id ? document.getElementById(id) : null;
      if (!target) return; // let the browser handle a missing target
      e.preventDefault();
      target.scrollIntoView({ behavior: reduce ? "auto" : "smooth", block: "start" });
      history.replaceState(null, "", `#${id}`);
      nav.classList.remove("is-open");
    };
    links.forEach((l) => l.addEventListener("click", onLinkClick));

    const onPill = () => {
      const open = nav.classList.toggle("is-open");
      pill?.setAttribute("aria-expanded", String(open));
    };
    pill?.addEventListener("click", onPill);

    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll, { passive: true });
    compute(); // set initial state (handles a deep-linked hash on load)

    teardown = () => {
      window.removeEventListener("scroll", onScroll);
      window.removeEventListener("resize", onScroll);
      links.forEach((l) => l.removeEventListener("click", onLinkClick));
      pill?.removeEventListener("click", onPill);
      if (raf) cancelAnimationFrame(raf);
      // restore the title so SPA navigation keeps the next page's own <title>
      if (DYNAMIC_TITLE) document.title = originalTitle;
      teardown = null;
      inited = false;
    };
  }

  // rebind on every view-transition load, tear down before each swap
  document.addEventListener("astro:before-swap", () => teardown?.());
  initCaseIndex();
  document.addEventListener("astro:page-load", initCaseIndex);
</script>
