---
import Base from "../layouts/Base.astro";

const channels = [
  { label: "Email", value: "howl@wittywolf.design", href: "mailto:howl@wittywolf.design" },
  { label: "WhatsApp / NL", value: "+31 653 215 989", href: "https://wa.me/31653215989" },
  { label: "Phone / ES", value: "+34 624 225 011", href: "tel:+34624225011" },
  { label: "LinkedIn", value: "in/marcorramos", href: "https://www.linkedin.com/in/marcorramos" },
];
---

<Base
  title="Contact · Witty Wolf Design"
  description="A project, a collaboration or just an idea worth talking through. The inbox is open, and I answer."
>
  <section class="section contact">
    <div class="wrap contact__grid">
      <div class="contact__intro">
        <h1 class="contact__title" data-reveal>Let&rsquo;s connect.</h1>
        <p class="lead muted" data-reveal>
          A project, a collaboration or just an idea worth talking through.
          The inbox is open, and I answer.
        </p>

        <div class="channels" data-reveal-group>
          {channels.map((c) => (
            <a class="channel" href={c.href} target={c.href.startsWith("http") ? "_blank" : undefined} rel="noopener" data-reveal>
              <span class="channel__label muted">{c.label}</span>
              <span class="channel__value ul">{c.value}</span>
            </a>
          ))}
        </div>
      </div>

      <!-- Form posts to Web3Forms (no backend needed on static hosting).
           Replace the access_key value below with the key Web3Forms emails you
           after you register marco@wittywolf.design at web3forms.com.
           novalidate: validation is handled in the script for custom messages. -->
      <form
        class="form"
        data-reveal
        action="https://api.web3forms.com/submit"
        method="POST"
        novalidate
      >
        <input type="hidden" name="access_key" value="73807b61-7306-4d25-8a68-6313659e3f96" />
        <input type="hidden" name="subject" value="New enquiry via wittywolf.design" />
        <input type="hidden" name="from_name" value="wittywolf.design" />
        <!-- honeypot: real people never see or fill this; bots do -->
        <input type="checkbox" name="botcheck" class="hp" tabindex="-1" autocomplete="off" aria-hidden="true" />

        <div class="field">
          <label for="name">Your name</label>
          <input id="name" name="name" type="text" autocomplete="name" placeholder="First name is fine" required />
          <p class="field__err" data-err="name" aria-live="polite"></p>
        </div>
        <div class="field">
          <label for="email">Email</label>
          <input id="email" name="email" type="email" autocomplete="email" placeholder="Where my reply should land" required />
          <p class="field__err" data-err="email" aria-live="polite"></p>
        </div>
        <div class="field">
          <label for="message">What&rsquo;s on your mind?</label>
          <textarea id="message" name="message" rows="5" placeholder="A project, a question, a half-formed idea. Rough is fine." required></textarea>
          <p class="field__err" data-err="message" aria-live="polite"></p>
        </div>
        <button type="submit" class="btn form__submit">
          Send message <span class="arrow" aria-hidden="true">&rarr;</span>
        </button>
        <p class="form__note muted">
          Prefer email? <a class="ul" href="mailto:howl@wittywolf.design">howl@wittywolf.design</a>
        </p>
      </form>
    </div>
  </section>
</Base>

<style>
  .contact__grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 6vw, 5rem); align-items: start; }
  .contact__title { margin: 1rem 0 1.25rem; }
  .channels { display: grid; gap: 0; margin-top: 2.5rem; }
  .channel {
    display: flex; justify-content: space-between; gap: 1rem; align-items: baseline;
    padding-block: 1.1rem; border-top: 1px solid var(--line);
  }
  .channel:last-child { border-bottom: 1px solid var(--line); }
  .channel__label { font-size: var(--step--1); text-transform: uppercase; letter-spacing: 0.06em; }
  .channel__value { font-family: var(--font-mono); font-weight: 600; font-size: var(--step-1); }

  /* field-notes, like everything else on the site: hairline ink borders,
     crisp corners, paper fields. The old rounded card was the one soft-UI
     island left over from the template era. */
  .form { display: grid; gap: 1.25rem; padding: clamp(1.5rem, 4vw, 2.5rem); background: var(--bg-elevated); border: 1px solid var(--ink); border-radius: 2px; }
  .field { display: grid; gap: 0.5rem; }
  .field label { font-size: var(--step--1); font-weight: 600; letter-spacing: 0.02em; }
  .field input, .field textarea {
    font: inherit; font-size: var(--step-0); color: var(--ink);
    padding: 0.85rem 1rem; border: 1px solid var(--line); border-radius: 2px;
    background: var(--paper); transition: border-color 0.25s ease;
    resize: vertical;
  }
  .field input::placeholder, .field textarea::placeholder { color: var(--grey-400); }
  .field input:focus, .field textarea:focus {
    outline: 2px solid var(--accent); outline-offset: 2px;
    border-color: var(--ink);
  }
  /* webkit autofill paints white by default; repaint with the theme */
  .field input:-webkit-autofill,
  .field input:-webkit-autofill:hover,
  .field input:-webkit-autofill:focus {
    -webkit-box-shadow: 0 0 0 1000px var(--paper) inset;
    -webkit-text-fill-color: var(--ink);
    caret-color: var(--ink);
    transition: background-color 999999s;
  }
  .form__submit { margin-top: 0.5rem; justify-self: start; }
  .channel:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; }
  .form__note { font-size: var(--step--1); }
  /* honeypot: visually and audibly hidden, off the tab order */
  .hp { position: absolute; left: -9999px; width: 1px; height: 1px; opacity: 0; }
  /* inline field guidance: plain ink mono, no red boxes */
  .field__err {
    font-family: var(--font-mono); font-size: var(--step--1);
    color: var(--ink); margin: 0.15rem 0 0; min-height: 1.15em;
    line-height: 1.3;
  }
  .field input.invalid, .field textarea.invalid {
    border-color: color-mix(in srgb, var(--accent) 65%, var(--ink));
  }
  /* terminal caret for the submit feedback */
  .form__submit .caret {
    display: inline-block; width: 0.55em; height: 1.05em;
    background: currentColor;
    vertical-align: text-bottom;
    animation: submit-blink 0.6s steps(2, start) infinite;
  }
  @keyframes submit-blink { 50% { opacity: 0; } }
  @media (max-width: 820px) { .contact__grid { grid-template-columns: 1fr; } }
</style>

<script>
  import { rand } from "../scripts/ink";

  // Terminal-style submit feedback: the label retypes to "SENDING..." with
  // a blinking caret, then "SENT." or a dry error line. Reduced motion gets
  // plain label swaps. The form posts via fetch so the page never leaves.
  let formInited = false;
  function initForm() {
    if (formInited) return;
    const form = document.querySelector<HTMLFormElement>(".form");
    const btn = form?.querySelector<HTMLButtonElement>(".form__submit");
    if (!form || !btn) return;
    formInited = true;
    const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
    const original = btn.innerHTML;
    let typeTimer = 0;

    const setLabel = (text: string, done?: () => void) => {
      window.clearTimeout(typeTimer);
      if (reduce) {
        btn.textContent = text;
        done?.();
        return;
      }
      btn.innerHTML = '<span class="caret" aria-hidden="true"></span>';
      const caret = btn.querySelector(".caret")!;
      let i = 0;
      const step = () => {
        if (i < text.length) {
          caret.insertAdjacentText("beforebegin", text[i]);
          i++;
          typeTimer = window.setTimeout(step, rand(26, 64));
        } else {
          done?.();
        }
      };
      step();
    };
    const restore = (after: number) => {
      window.setTimeout(() => {
        window.clearTimeout(typeTimer);
        btn.innerHTML = original;
        btn.disabled = false;
        btn.style.minWidth = "";
      }, after);
    };

    // Inline validation with plain-spoken guidance. novalidate on the form
    // hands control here so the messages read in Marco's voice, not the
    // browser's generic bubble.
    const fields: Record<string, HTMLInputElement | HTMLTextAreaElement | null> = {
      name: form.querySelector("#name"),
      email: form.querySelector("#email"),
      message: form.querySelector("#message"),
    };
    // one @, something before and after it, and a dotted domain. Rejects
    // a@@b.com, marco@, marco@site (no dot), and anything with spaces.
    const emailOk = (v: string) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v);
    const setErr = (key: string, msg: string) => {
      const el = form.querySelector<HTMLElement>(`[data-err="${key}"]`);
      if (el) el.textContent = msg;
      fields[key]?.classList.toggle("invalid", !!msg);
    };
    const validate = () => {
      let firstBad: HTMLElement | null = null;
      const flag = (key: string, bad: boolean, msg: string) => {
        setErr(key, bad ? msg : "");
        if (bad && !firstBad) firstBad = fields[key] as HTMLElement;
      };
      const name = fields.name?.value.trim() ?? "";
      const email = fields.email?.value.trim() ?? "";
      const message = fields.message?.value.trim() ?? "";
      flag("name", !name, "A name, even just the first one.");
      flag("email", !email || !emailOk(email),
        !email ? "Need an email so I can write back."
               : "That address looks off. Check the @ and the part after it.");
      flag("message", !message, "Tell me a little about it. Rough is fine.");
      if (firstBad) (firstBad as HTMLElement).focus();
      return !firstBad;
    };
    // clear a field's message the moment it becomes valid
    for (const key of Object.keys(fields)) {
      fields[key]?.addEventListener("input", () => {
        const v = fields[key]?.value.trim() ?? "";
        if (key === "email") { if (v && emailOk(v)) setErr("email", ""); }
        else if (v) setErr(key, "");
      });
    }

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (btn.disabled) return;
      if (!validate()) return;
      btn.disabled = true;
      // hold the box steady while the label retypes; it may still grow
      btn.style.minWidth = `${btn.offsetWidth}px`;
      setLabel("Sending...");
      try {
        const res = await fetch(form.action, {
          method: "POST",
          body: new FormData(form),
          headers: { Accept: "application/json" },
        });
        if (!res.ok) throw new Error(String(res.status));
        setLabel("Sent.", () => form.reset());
        restore(4000);
      } catch {
        setLabel("Didn't send. Try howl@wittywolf.design");
        restore(7000);
      }
    });
  }
  document.addEventListener("astro:before-swap", () => (formInited = false));
  initForm();
  document.addEventListener("astro:page-load", initForm);
</script>
