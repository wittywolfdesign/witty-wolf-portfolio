---
import Base from "../layouts/Base.astro";
---

<Base title="Lost the scent · Witty Wolf Design">
  <section class="section center nf">
    <div class="wrap">
      <h1 data-reveal>This page lost the scent.</h1>
      <p class="lead muted" data-reveal>The link is broken or the page moved on.</p>
      <a href="/" class="btn" data-reveal style="margin-top:2rem">
        Back home <span class="arrow" aria-hidden="true">&rarr;</span>
      </a>
    </div>
  </section>
</Base>

<style>
  .nf { min-height: 60vh; display: grid; place-items: center; }
</style>
